# --- pushcv local, per-user data (never commit) ---
pushcv.db
*.db
.pushcv.json          # per-workspace preferences (e.g. AI salary toggle)
profile.md            # your personal master profile (generated by `pushcv init`)
drafts/               # AI-generated resume drafts
*.cast                # asciinema recordings
media/                # rendered video/GIF assets

# --- secrets / env ---
.env
.env.*

# --- scraper debug dumps (pushcv fetch --debug) ---
linkedin_*.html

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- OS / editor ---
.DS_Store
*.swp
.idea/
.vscode/
